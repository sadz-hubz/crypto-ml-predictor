    "# Predict with best model\n",
    "if best_name == 'LSTM':\n",
    "    latest_seq = X_scaled[-SEQ_LEN:].reshape(1, SEQ_LEN, -1)\n",
    "    prob_up = model.predict(latest_seq)[0][0]\n",
    "    pred = 1 if prob_up > 0.5 else 0\n",
